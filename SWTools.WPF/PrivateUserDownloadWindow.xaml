<Window x:Class="SWTools.WPF.PrivateUserDownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SWTools.WPF"
        xmlns:controls="clr-namespace:SWTools.WPF.Controls"
        xmlns:gif="https://github.com/XamlAnimatedGif/XamlAnimatedGif"
        xmlns:viewmodel="clr-namespace:SWTools.ViewModel;assembly=SWTools.ViewModel"
        mc:Ignorable="d"
        Title="Steam Workshop Tools (SWTools)" 
        Height="415" Width="536"
        MinHeight="400" MinWidth="500"
        Background="{StaticResource BhDefault}" ThemeMode="Light"
        WindowStartupLocation="CenterScreen"
        RenderOptions.BitmapScalingMode="HighQuality">
    <Window.DataContext>
        <viewmodel:MainWindow/>
    </Window.DataContext>
    <Grid Margin="0,0,0,-5">
        <TextBox x:Name="Steam_user" HorizontalAlignment="Left" Margin="10,31,0,0" TextWrapping="Wrap" Text="User" 
                   VerticalAlignment="Top" Width="129" Height="20"/>
        <TextBox x:Name="Steam_Passwd" HorizontalAlignment="Left" Margin="10,90,0,0" TextWrapping="Wrap" Text="Passwd" 
            VerticalAlignment="Top" Width="129" Height="20"/>
        <Button x:Name ="Add_User" Content="添加" Margin="12,142,0,0" VerticalAlignment="Top" Click="BtnAdd_User_Click"/>
        <ComboBox x:Name ="UserChoose" HorizontalAlignment="Left" Margin="190,31,0,0" VerticalAlignment="Top" Width="144"/>
        <TextBox HorizontalAlignment="Left" Margin="156,90,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="212" Height="121"/>
        <DockPanel LastChildFill="False" Margin="0,324,0,0" Background="WhiteSmoke" RenderTransformOrigin="0.5,0.5">
            <controls:IconButtonAccent x:Name="BtnOk" Click="btn_Download"
                Text="下载" Icon="&#xE8FB;" DockPanel.Dock="Right" Margin="10 10 20 10" Height="53" Width="79"  />
        </DockPanel>

    </Grid>
</Window>
